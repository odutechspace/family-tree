# Copy to .env and fill in values. Next.js loads .env automatically.

# MySQL (TypeORM) — create the database first, e.g.:
# CREATE DATABASE my_ukoo CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=my_ukoo

# JWT for cookie/session tokens (use a long random string in production)
JWT_SECRET=

# Redis (BullMQ) — required for outbound mail. Run: npm run worker:mail
# REDIS_URL=redis://localhost:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# Optional: outbound mail (processed by worker, not the Next.js server)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
MAIL_FROM=no-reply@example.com
SMTP_USER=
SMTP_PASS=
